an class="mtk1">tokens</span><span class="mtk14">])</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;x_demo&nbsp;&nbsp;=&nbsp;torch.tensor</span><span class="mtk14">(</span><span class="mtk1">vec</span><span class="mtk14">,</span><span class="mtk1">&nbsp;dtype=torch.float32</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;model.</span><span class="mtk17">eval</span><span class="mtk14">()</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">with</span><span class="mtk1">&nbsp;torch.no_grad</span><span class="mtk14">():</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;logit&nbsp;&nbsp;=&nbsp;model</span><span class="mtk14">(</span><span class="mtk1">x_demo</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;prob&nbsp;&nbsp;&nbsp;=&nbsp;torch.softmax</span><span class="mtk14">(</span><span class="mtk1">logit</span><span class="mtk14">,</span><span class="mtk1">&nbsp;dim=</span><span class="mtk6">1</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pred&nbsp;&nbsp;&nbsp;=&nbsp;prob.argmax</span><span class="mtk14">()</span><span class="mtk1">.item</span><span class="mtk14">()</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;label&nbsp;=&nbsp;</span><span class="mtk5">'😊&nbsp;Positive'</span><span class="mtk1">&nbsp;</span><span class="mtk20">if</span><span class="mtk1">&nbsp;pred&nbsp;==&nbsp;</span><span class="mtk6">1</span><span class="mtk1">&nbsp;</span><span class="mtk20">else</span><span class="mtk1">&nbsp;</span><span class="mtk5">'😞&nbsp;Negative'</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;conf&nbsp;&nbsp;=&nbsp;prob</span><span class="mtk14">[</span><span class="mtk6">0</span><span class="mtk14">,</span><span class="mtk1">&nbsp;pred</span><span class=