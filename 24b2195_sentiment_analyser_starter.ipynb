(</span><span class="mtk1">y_test</span><span class="mtk14">,</span><span class="mtk1">&nbsp;dtype=torch.</span><span class="mtk4">long</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">train_dataset&nbsp;=&nbsp;TensorDataset</span><span class="mtk14">(</span><span class="mtk1">X_tr</span><span class="mtk14">,</span><span class="mtk1">&nbsp;y_tr</span><span class="mtk14">)</span></span><br><span><span class="mtk1">train_loader&nbsp;&nbsp;=&nbsp;DataLoader</span><span class="mtk14">(</span><span class="mtk1">train_dataset</span><span class="mtk14">,</span><span class="mtk1">&nbsp;batch_size=</span><span class="mtk6">64</span><span class="mtk14">,</span><span class="mtk1">&nbsp;shuffle=</span><span class="mtk9">True</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;=====&nbsp;Define&nbsp;the&nbsp;MLP&nbsp;=====</span></span><br><span><span class="mtk10">class</span><span class="mtk1">&nbsp;</span><span class="mtk16">SentimentMLP</span><span class="mtk1">(</span><span class="mtk16">nn</span><span class="mtk1">.</span><span class="mtk16">Module</span><span class="mtk1">)</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk10">def</span><span class="mtk1">&nbsp;</span><span class="mtk17">__init__</span><span class="mtk1">(</span><span class="mtk4">self</span><span class="mtk1">,&nbsp;</span><span class="mtk4">input_dim</span><span class="mtk1">,&nbsp;</span><span class="mtk4">hidden1</span><span class="mtk1">=</span><span class="mtk6">256</span><span class="mtk1">,&nbsp;</span><span class="mtk4">hidden2</span><span class="mtk1">=</span><span class="mtk6">128</span><span class="mtk1">,&nbsp;</span><span class="mtk4">num_classes</span><span class="mtk1">=</span><span class="mtk6">2</span><span class="mtk1">)</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nb